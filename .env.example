# ============================================
# EONTYRE API Configuration
# ============================================
# Backend API URL (replace with your actual backend)
# Local: http://127.0.0.1:4000
# Production: https://your-backend-domain.com
BACKEND_API_URL=https://your-production-backend.com

INTERNAL_API_URL=https://your-production-backend.com

# EONTYRE API Key (get from EONTYRE support - NEVER commit real key)
# Add this in Vercel Environment Variables, NOT in this file
REACT_APP_EONTYRE_API_KEY=your_api_key_here

# ============================================
# Language Configuration
# ============================================
REACT_APP_DEFAULT_LANG=sv

# ============================================
# Database (if needed)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/sales_management
