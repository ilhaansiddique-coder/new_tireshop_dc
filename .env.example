# ============================================
# EonTyre API
# ============================================
EONTYRE_API_URL=https://p511.eontyre.com
EONTYRE_API_KEY=your_eontyre_api_key_here

# ============================================
# Qliro Payment
# ============================================
# Set QLIRO_API_KEY=DACKA to enable mock-payment mode (auto-completes after 3s, no real charge).
# For production: replace with your real merchant key + secret.
QLIRO_API_KEY=DACKA
QLIRO_API_SECRET=your_qliro_secret_here
QLIRO_API_URL=https://pago.qit.nu

# ============================================
# Public URL
# ============================================
# Used by Qliro for redirect after payment. No trailing slash.
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ============================================
# Fraktjakt Shipping
# ============================================
FRAKTJAKT_CONSIGNOR_ID=your_consignor_id
FRAKTJAKT_CONSIGNOR_KEY=your_consignor_key
SHOP_ORIGIN_STREET=Musköstgatan 2
SHOP_ORIGIN_POSTAL=25220
SHOP_ORIGIN_CITY=Helsingborg

# Fraktjakt booking mode:
#   "shipment" (default) → admin picks carrier in Fraktjakt dashboard
#   "order"              → uses customer's chosen carrier (Order API type 1)
# Auto-paying labels still requires invoice/credit billing on the Fraktjakt account.
FRAKTJAKT_BOOKING_MODE=shipment

# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=3000
