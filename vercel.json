{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*\\.html)",
      "destination": "/$1"
    },
    {
      "source": "^/(?!.*\\.)",
      "destination": "/index.html"
    }
  ]
}
