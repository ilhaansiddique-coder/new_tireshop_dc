{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(?!api)(.*)\\.html$",
      "destination": "/$1.html"
    },
    {
      "source": "/(?!api).*",
      "destination": "/index.html"
    }
  ]
}
