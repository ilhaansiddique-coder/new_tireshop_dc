{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/om-oss",
      "destination": "/om-oss.html"
    },
    {
      "source": "/dackhotell",
      "destination": "/dackhotell.html"
    },
    {
      "source": "/tjanst-:service",
      "destination": "/tjanst-:service.html"
    }
  ]
}
