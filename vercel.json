{
  "cleanUrls": true,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/om-oss",
      "destination": "/om-oss.html"
    },
    {
      "source": "/dackhotell",
      "destination": "/dackhotell.html"
    },
    {
      "source": "/tjanst-:service",
      "destination": "/tjanst-:service.html"
    }
  ]
}
